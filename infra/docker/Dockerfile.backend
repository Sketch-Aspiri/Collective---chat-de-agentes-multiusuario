# =========================================================================
# Backend multistage Dockerfile — builder -> development -> production
# Contexto de build esperado: raíz del repo (./)
# =========================================================================

# ---- Stage 1: builder (compila TypeScript y genera el cliente de Prisma) ----
FROM node:20-alpine AS builder
WORKDIR /app
# OpenSSL: requerido por el motor de Prisma en Alpine (musl)
RUN apk add --no-cache openssl libc6-compat
COPY backend/package*.json ./
# --legacy-peer-deps: bullmq declara redis>=5 como peerOptional y el proyecto usa redis@^4
RUN npm install --legacy-peer-deps
COPY backend/prisma ./prisma
RUN npx prisma generate
COPY backend/tsconfig.json ./
COPY backend/src ./src
RUN npm run build

# ---- Stage 2: development (hot-reload con ts-node-dev) ----
FROM node:20-alpine AS development
WORKDIR /app
ENV NODE_ENV=development
RUN apk add --no-cache openssl libc6-compat
COPY backend/package*.json ./
RUN npm install --legacy-peer-deps
COPY backend/prisma ./prisma
RUN npx prisma generate
COPY backend/tsconfig.json ./
COPY backend/src ./src
EXPOSE 4000
CMD ["npm", "run", "dev"]

# ---- Stage 3: production (imagen mínima solo con deps de runtime) ----
FROM node:20-alpine AS production
WORKDIR /app
ENV NODE_ENV=production
RUN apk add --no-cache openssl libc6-compat
COPY backend/package*.json ./
RUN npm install --omit=dev --legacy-peer-deps
# Cliente de Prisma ya generado en el builder (evita necesitar el CLI en prod)
COPY --from=builder /app/node_modules/.prisma ./node_modules/.prisma
COPY --from=builder /app/dist ./dist
COPY backend/prisma ./prisma
EXPOSE 4000
# El entrypoint real que hace listen() es dist/server.js (no index.js)
CMD ["node", "dist/server.js"]
