# =========================================================================
# Frontend multistage Dockerfile — builder -> development -> production
# Contexto de build esperado: raíz del repo (./)
# =========================================================================

# ---- Stage 1: builder (build de Vite a estáticos) ----
FROM node:20-alpine AS builder
WORKDIR /app
COPY frontend/package*.json ./
RUN npm install
COPY frontend ./
RUN npm run build

# ---- Stage 2: development (Vite dev server con hot-reload) ----
FROM node:20-alpine AS development
WORKDIR /app
ENV NODE_ENV=development
COPY frontend/package*.json ./
RUN npm install
COPY frontend ./
EXPOSE 5173
# --host 0.0.0.0 expone el dev server fuera del contenedor
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]

# ---- Stage 3: production (estáticos servidos por nginx) ----
FROM nginx:alpine AS production
COPY --from=builder /app/dist /usr/share/nginx/html
COPY infra/docker/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
